  <script>
    // ── INIT ────────────────────────────────────────────────
    // Stripe elements are still needed for the card input, but the full Stripe object is not used for this simplified payment
    const elements = Stripe('pk_test_TYooMQauvdEDq542VcVEqKDfB').elements({ appearance: { theme: 'night', variables: { colorPrimary: '#C9A84C', colorBackground: '#161616', colorText: '#f0ede8', colorDanger: '#e05555', fontFamily: 'Montserrat, sans-serif', borderRadius: '0px' } } });
    const cardElement = elements.create('card', { style: { base: { color: '#f0ede8', fontFamily: '"Montserrat", sans-serif', fontSize: '14px', '::placeholder': { color: '#7a7670' } } } });

    // ── STATE ────────────────────────────────────────────────
    const state = {
      service: null, servicePrice: null,
      packageName: null, packagePrice: null, packagePriceCents: null,
      date: null, dateFormatted: null, time: null,
      currentMonth: new Date().getMonth(), currentYear: new Date().getFullYear()
    };

    const packages = {
      'Videography': [
        { name: 'Essential', price: 'GHc800', cents: 80000, features: ['2-hour shoot', '1 edited video', '1080p delivery', '3 revisions'] },
        { name: 'Signature', price: 'GHc1,500', cents: 150000, features: ['4-hour shoot', '2 edited videos', '4K delivery', '5 revisions', 'Color grading'], featured: true },
        { name: 'Prestige', price: 'GHc3,000', cents: 300000, features: ['Full-day shoot', '5 edited videos', '4K + RAW files', 'Unlimited revisions', 'Drone footage', 'Same-week delivery'] }
      ],
      'Photography': [
        { name: 'Essential', price: 'GHc350', cents: 35000, features: ['1-hour shoot', '20 edited images', 'Digital delivery', '2 revisions'] },
        { name: 'Signature', price: 'GHc750', cents: 75000, features: ['3-hour shoot', '60 edited images', 'Digital + Print', '4 revisions', 'Styling consult'], featured: true },
        { name: 'Prestige', price: 'GHc1,400', cents: 140000, features: ['Full-day shoot', '150+ edited images', 'RAW + Edited', 'Unlimited revisions', 'Rush delivery', 'Printing service'] }
      ],
      'Podcast': [
        { name: 'Essential', price: 'GHc500', cents: 50000, features: ['1 episode recorded', 'Basic audio edit', 'MP3 delivery', '1 revision'] },
        { name: 'Signature', price: 'GHc1,000', cents: 100000, features: ['3 episodes', 'Video + Audio', 'Full post-production', 'Thumbnail design', 'Show notes'], featured: true },
        { name: 'Prestige', price: 'GHc2,200', cents: 220000, features: ['10 episodes', 'Full production', 'Branding package', 'Distribution setup', 'Monthly support'] }
      ],
      'Graphic Design': [
        { name: 'Essential', price: 'GHc250', cents: 25000, features: ['1 design concept', '3 file formats', '2 revisions', '3-day turnaround'] },
        { name: 'Signature', price: 'GHc600', cents: 60000, features: ['3 design concepts', 'Full brand kit', '5 revisions', 'Source files', '48hr turnaround'], featured: true },
        { name: 'Prestige', price: 'GHc1,200', cents: 120000, features: ['Full brand identity', 'Unlimited concepts', 'All source files', 'Brand guide', 'Priority support'] }
      ]
    };

    const times = ['9:00 AM', '10:00 AM', '11:00 AM', '12:00 PM', '2:00 PM', '3:00 PM', '4:00 PM', '5:00 PM'];
    const unavailTimes = ['11:00 AM', '3:00 PM'];

    // ── STRIPE MOUNT ─────────────────────────────────────────
    function mountCard() {
      setTimeout(() => {
        cardElement.mount('#card-element');
        cardElement.on('focus', () => document.getElementById('card-element').classList.add('focused'));
        cardElement.on('blur', () => document.getElementById('card-element').classList.remove('focused'));
        cardElement.on('change', e => { document.getElementById('card-errors').textContent = e.error ? e.error.message : ''; });
      }, 100);
    }

    // ── SERVICE ───────────────────────────────────────────────
    function selectService(el, name, price) {
      document.querySelectorAll('.service-option').forEach(e => e.classList.remove('selected'));
      el.classList.add('selected');
      state.service = name; state.servicePrice = price;
      document.getElementById('next1').disabled = false;
    }

    // ── PACKAGES ──────────────────────────────────────────────
    function renderPackages() {
      const grid = document.getElementById('packagesGrid');
      grid.innerHTML = '';
      (packages[state.service] || []).forEach(pkg => {
        grid.innerHTML += `<div class="package-card${pkg.featured ? ' featured' : ''}" onclick="selectPackage(this,'${pkg.name}','${pkg.price}',${pkg.cents})">
      <div class="package-name">${pkg.name}</div>
      <div class="package-price">${pkg.price} <span>/ session</span></div>
      <ul class="package-features">${pkg.features.map(f => `<li>${f}</li>`).join('')}</ul>
    </div>`;
      });
    }

    function selectPackage(el, name, price, cents) {
      document.querySelectorAll('.package-card').forEach(e => e.classList.remove('selected'));
      el.classList.add('selected');
      state.packageName = name; state.packagePrice = price; state.packagePriceCents = cents;
      document.getElementById('next2').disabled = false;
    }

    // ── CALENDAR ──────────────────────────────────────────────
    const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
    const MONTHS_SHORT = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

    function renderCalendar() {
      document.getElementById('calMonth').textContent = `${MONTHS[state.currentMonth]} ${state.currentYear}`;
      const grid = document.getElementById('calGrid');
      grid.innerHTML = '';
      const firstDay = new Date(state.currentYear, state.currentMonth, 1).getDay();
      const daysInMonth = new Date(state.currentYear, state.currentMonth + 1, 0).getDate();
      const today = new Date();
      for (let i = 0; i < firstDay; i++) grid.innerHTML += `<div class="cal-day empty"></div>`;
      for (let d = 1; d <= daysInMonth; d++) {
        const date = new Date(state.currentYear, state.currentMonth, d);
        const isPast = date < new Date(today.getFullYear(), today.getMonth(), today.getDate());
        const isToday = date.toDateString() === today.toDateString();
        const isSelected = state.date === `${state.currentYear}-${state.currentMonth}-${d}`;
        const cls = ['cal-day', isPast ? 'past' : '', isToday ? 'today' : '', isSelected ? 'selected' : ''].join(' ').trim();
        grid.innerHTML += `<div class="${cls}" onclick="${isPast ? '' : `selectDate(this,${d})`}">${d}</div>`;
      }
    }

    function selectDate(el, day) {
      document.querySelectorAll('.cal-day').forEach(e => e.classList.remove('selected'));
      el.classList.add('selected');
      state.date = `${state.currentYear}-${state.currentMonth + 1}-${day}`;
      state.dateFormatted = `${MONTHS_SHORT[state.currentMonth]} ${day}, ${state.currentYear}`;
      checkSchedule();
    }

    function changeMonth(dir) {
      state.currentMonth += dir;
      if (state.currentMonth > 11) { state.currentMonth = 0; state.currentYear++; }
      if (state.currentMonth < 0) { state.currentMonth = 11; state.currentYear--; }
      renderCalendar();
    }

    function renderTimes() {
      document.getElementById('timeGrid').innerHTML = times.map(t => {
        const ua = unavailTimes.includes(t);
        return `<div class="time-slot${ua ? ' unavailable' : ''}" onclick="${ua ? '' : `selectTime(this,'${t}')`}">${t}${ua ? '<br><span style="font-size:0.55rem;color:var(--text-dim)">Unavail.</span>' : ''}</div>`;
      }).join('');
    }

    function selectTime(el, time) {
      document.querySelectorAll('.time-slot').forEach(e => e.classList.remove('selected'));
      el.classList.add('selected');
      state.time = time;
      checkSchedule();
    }

    function checkSchedule() {
      document.getElementById('next3').disabled = !(state.date && state.time);
    }

    // ── DETAILS ───────────────────────────────────────────────
    function checkDetails() {
      const ok = document.getElementById('fname').value.trim() && document.getElementById('email').value.trim();
      document.getElementById('next4').disabled = !ok;
    }

    // ── STEP NAV ──────────────────────────────────────────────
    function goToStep(n) {
      for (let i = 1; i <= 5; i++) {
        document.getElementById(`panel${i}`).classList.remove('active');
        const s = document.getElementById(`step${i}`);
        s.classList.remove('active', 'done');
        if (i < n) s.classList.add('done');
        if (i === n) s.classList.add('active');
      }
      document.getElementById(`panel${n}`).classList.add('active');
      if (n === 2) renderPackages();
      if (n === 3) { renderCalendar(); renderTimes(); }
      if (n === 5) { populateReview(); }
      document.getElementById('booking').scrollIntoView({ behavior: 'smooth' });
    }

    function populateReview() {
      document.getElementById('rv-service').textContent = state.service || '—';
      document.getElementById('rv-package').textContent = `${state.packageName} — ${state.packagePrice}`;
      document.getElementById('rv-datetime').textContent = `${state.dateFormatted || '—'} at ${state.time || '—'}`;
      const fn = document.getElementById('fname').value, ln = document.getElementById('lname').value;
      document.getElementById('rv-client').textContent = `${fn} ${ln}`.trim();
      document.getElementById('rv-total').textContent = state.packagePrice;
    }

    // ── PAYMENT ───────────────────────────────────────────────
    // ── PAYMENT ───────────────────────────────────────────────
    async function handlePayment() {
      const btn = document.getElementById('payBtn');
      const spinner = document.getElementById('paySpinner');
      btn.disabled = true; spinner.style.display = 'block';

      try {
        const bookingData = {
          service: state.service,
          package_name: state.packageName,
          package_price: state.packagePrice,
          amount_cents: state.packagePriceCents,
          booking_date: state.date,
          booking_time: state.time,
          client_name: `${document.getElementById('fname').value} ${document.getElementById('lname').value}`.trim(),
          client_email: document.getElementById('email').value,
          client_phone: document.getElementById('phone').value,
          project_brief: document.getElementById('brief').value,
          referral_source: document.getElementById('source').value,
          stripe_payment_id: 'manual_payment_' + Date.now(), // Simplified for this demo
        };

        const res = await fetch('/api/bookings/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(bookingData)
        });

        const result = await res.json();
        if (!result.success) throw new Error(result.error);

        showSuccess(result.ref);

      } catch (err) {
        showToast(err.message, true);
        btn.disabled = false; spinner.style.display = 'none';
      }
    }

    function showSuccess(ref) {
      document.getElementById('stepsBar').style.display = 'none';
      for (let i = 1; i <= 5; i++) document.getElementById(`panel${i}`).style.display = 'none';
      const s = document.getElementById('success-panel');
      s.style.display = 'block';
      document.getElementById('bookingRef').textContent = `REF: ${ref}`;
      document.getElementById('booking').scrollIntoView({ behavior: 'smooth' });
    }

    function resetBooking() {
      document.getElementById('stepsBar').style.display = 'flex';
      document.getElementById('success-panel').style.display = 'none';
      for (let i = 1; i <= 5; i++) document.getElementById(`panel${i}`).style.display = '';
      Object.keys(state).forEach(k => { if (!['currentMonth', 'currentYear'].includes(k)) state[k] = null; });
      goToStep(1);
      document.querySelectorAll('.service-option').forEach(e => e.classList.remove('selected'));
      document.getElementById('next1').disabled = true;
    }

    // ── TOAST ────────────────────────────────────────────────
    function showToast(msg, isError = false) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = `toast${isError ? ' error' : ''} show`;
      setTimeout(() => t.classList.remove('show'), 4000);
    }

    renderCalendar();
  </script>
</body>

</html>