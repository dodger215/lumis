<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LUMIS — Creative Studio Booking</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <script src="https://js.stripe.com/v3/"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --gold: #C9A84C;
      --gold-light: #E8C97A;
      --gold-dim: #7a6530;
      --bg: #080808;
      --surface: #0f0f0f;
      --surface2: #161616;
      --surface3: #1e1e1e;
      --text: #f0ede8;
      --text-muted: #7a7670;
      --text-dim: #3a3835;
      --border: #222;
      --border-gold: rgba(201, 168, 76, 0.25);
      --error: #e05555;
      --success: #4caf7d;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9999;
      opacity: 0.5;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    }

    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 24px 60px;
      background: linear-gradient(to bottom, rgba(8, 8, 8, 0.95), transparent);
      backdrop-filter: blur(8px);
    }

    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.8rem;
      font-weight: 300;
      letter-spacing: 0.3em;
      color: var(--gold);
    }

    .nav-links {
      display: flex;
      gap: 40px;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--text-muted);
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      transition: color 0.3s;
    }

    .nav-links a:hover {
      color: var(--gold);
    }

    .nav-cta {
      background: transparent;
      border: 1px solid var(--gold);
      color: var(--gold);
      padding: 10px 28px;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.3s;
    }

    .nav-cta:hover {
      background: var(--gold);
      color: var(--bg);
    }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 120px 40px 80px;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 50% at 50% 60%, rgba(201, 168, 76, 0.06) 0%, transparent 70%), radial-gradient(ellipse 30% 30% at 20% 20%, rgba(201, 168, 76, 0.04) 0%, transparent 60%);
    }

    .hero-line {
      width: 1px;
      height: 80px;
      background: linear-gradient(to bottom, transparent, var(--gold), transparent);
      margin-bottom: 48px;
      animation: pulse 3s ease-in-out infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 0.4
      }

      50% {
        opacity: 1
      }
    }

    .hero-eyebrow {
      font-size: 0.65rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 24px;
      font-weight: 500;
    }

    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.5rem, 8vw, 7rem);
      font-weight: 300;
      line-height: 1.05;
      color: var(--text);
      margin-bottom: 8px;
    }

    .hero-title em {
      font-style: italic;
      color: var(--gold-light);
    }

    .hero-subtitle {
      font-size: 0.75rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin: 32px 0 48px;
      max-width: 500px;
      line-height: 2;
    }

    .hero-cta {
      display: flex;
      gap: 20px;
      align-items: center;
    }

    .btn-primary {
      background: var(--gold);
      color: var(--bg);
      border: none;
      padding: 16px 48px;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.3s;
      font-weight: 600;
    }

    .btn-primary:hover {
      background: var(--gold-light);
      transform: translateY(-1px);
      box-shadow: 0 8px 30px rgba(201, 168, 76, 0.3);
    }

    .btn-primary:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    .btn-ghost {
      background: transparent;
      color: var(--text-muted);
      border: none;
      padding: 16px 24px;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      cursor: pointer;
      transition: color 0.3s;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .btn-ghost:hover {
      color: var(--text);
    }

    .btn-ghost::after {
      content: '→';
      transition: transform 0.3s;
    }

    .btn-ghost:hover::after {
      transform: translateX(4px);
    }

    /* SERVICES */
    .section {
      padding: 120px 60px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .section-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 80px;
    }

    .section-label {
      font-size: 0.6rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 16px;
      display: block;
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.5rem, 4vw, 4rem);
      font-weight: 300;
      line-height: 1.1;
    }

    .section-title em {
      font-style: italic;
      color: var(--gold-light);
    }

    .section-count {
      font-family: 'Cormorant Garamond', serif;
      font-size: 6rem;
      font-weight: 300;
      color: var(--text-dim);
      line-height: 1;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2px;
      background: var(--border);
    }

    .service-card {
      background: var(--surface);
      padding: 56px 48px;
      cursor: pointer;
      transition: all 0.4s;
      position: relative;
      overflow: hidden;
      border: 1px solid transparent;
    }

    .service-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(201, 168, 76, 0.06) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 0.4s;
    }

    .service-card:hover {
      background: var(--surface2);
      border-color: var(--border-gold);
      transform: translateY(-2px);
    }

    .service-card:hover::before {
      opacity: 1;
    }

    .service-number {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.8rem;
      color: var(--gold-dim);
      letter-spacing: 0.2em;
      margin-bottom: 32px;
      display: block;
    }

    .service-icon {
      width: 48px;
      height: 48px;
      margin-bottom: 28px;
      color: var(--gold);
      opacity: 0.8;
    }

    .service-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 400;
      margin-bottom: 16px;
    }

    .service-desc {
      font-size: 0.72rem;
      line-height: 1.9;
      color: var(--text-muted);
      letter-spacing: 0.05em;
      margin-bottom: 32px;
    }

    .service-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 32px;
    }

    .tag {
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--gold-dim);
      border: 1px solid var(--gold-dim);
      padding: 5px 12px;
    }

    .service-price {
      display: flex;
      align-items: baseline;
      gap: 4px;
    }

    .price-from {
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .price-amount {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.8rem;
      font-weight: 400;
      color: var(--gold);
    }

    .service-arrow {
      position: absolute;
      bottom: 48px;
      right: 48px;
      width: 40px;
      height: 40px;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      transition: all 0.3s;
      font-size: 1rem;
    }

    .service-card:hover .service-arrow {
      border-color: var(--gold);
      color: var(--gold);
      transform: translate(2px, -2px);
    }

    /* BOOKING */
    #booking {
      background: var(--surface);
      border-top: 1px solid var(--border);
      padding: 120px 60px;
    }

    .booking-container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .steps-bar {
      display: flex;
      align-items: center;
      margin-bottom: 80px;
      gap: 0;
    }

    .step-item {
      display: flex;
      align-items: center;
      gap: 16px;
      flex: 1;
      position: relative;
    }

    .step-item:not(:last-child)::after {
      content: '';
      position: absolute;
      left: calc(50% + 20px);
      right: -20px;
      top: 50%;
      height: 1px;
      background: var(--border);
      transform: translateY(-50%);
    }

    .step-item.done::after,
    .step-item.active::after {
      background: var(--gold-dim);
    }

    .step-num {
      width: 40px;
      height: 40px;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      flex-shrink: 0;
      transition: all 0.3s;
    }

    .step-item.active .step-num {
      border-color: var(--gold);
      color: var(--gold);
      background: rgba(201, 168, 76, 0.08);
    }

    .step-item.done .step-num {
      border-color: var(--gold-dim);
      background: var(--gold-dim);
      color: var(--bg);
    }

    .step-label {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
      transition: color 0.3s;
    }

    .step-item.active .step-label {
      color: var(--text);
    }

    .booking-panel {
      display: none;
    }

    .booking-panel.active {
      display: block;
    }

    /* SERVICE OPTIONS */
    .service-options {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 48px;
    }

    .service-option {
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 32px 24px;
      cursor: pointer;
      transition: all 0.3s;
      text-align: center;
    }

    .service-option:hover,
    .service-option.selected {
      border-color: var(--gold);
      background: rgba(201, 168, 76, 0.05);
    }

    .service-option-icon {
      font-size: 2rem;
      margin-bottom: 16px;
      display: block;
    }

    .service-option-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      margin-bottom: 8px;
    }

    .service-option-price {
      font-size: 0.65rem;
      color: var(--gold);
      letter-spacing: 0.1em;
    }

    /* PACKAGES */
    .packages-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 48px;
    }

    .package-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 40px 32px;
      cursor: pointer;
      transition: all 0.3s;
      position: relative;
    }

    .package-card.featured {
      border-color: var(--gold-dim);
    }

    .package-card.featured::before {
      content: 'MOST POPULAR';
      position: absolute;
      top: -1px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--gold);
      color: var(--bg);
      font-size: 0.5rem;
      letter-spacing: 0.2em;
      padding: 5px 16px;
      font-weight: 600;
    }

    .package-card:hover,
    .package-card.selected {
      border-color: var(--gold);
      background: rgba(201, 168, 76, 0.05);
    }

    .package-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      margin-bottom: 8px;
    }

    .package-price {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.5rem;
      color: var(--gold);
      margin-bottom: 24px;
    }

    .package-price span {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.7rem;
      color: var(--text-muted);
    }

    .package-features {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .package-features li {
      font-size: 0.7rem;
      color: var(--text-muted);
      letter-spacing: 0.05em;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .package-features li::before {
      content: '—';
      color: var(--gold-dim);
      flex-shrink: 0;
    }

    /* CALENDAR */
    .datetime-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      margin-bottom: 48px;
    }

    .calendar-label {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 24px;
      display: block;
    }

    .calendar {
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 32px;
    }

    .cal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 28px;
    }

    .cal-month {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
    }

    .cal-nav {
      background: none;
      border: 1px solid var(--border);
      color: var(--text-muted);
      width: 32px;
      height: 32px;
      cursor: pointer;
      font-size: 0.8rem;
      transition: all 0.3s;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .cal-nav:hover {
      border-color: var(--gold);
      color: var(--gold);
    }

    .cal-days-header {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 4px;
      margin-bottom: 8px;
    }

    .cal-day-name {
      font-size: 0.55rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-align: center;
      padding: 8px 0;
    }

    .cal-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 4px;
    }

    .cal-day {
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      cursor: pointer;
      transition: all 0.2s;
      color: var(--text-muted);
      border: 1px solid transparent;
    }

    .cal-day:not(.empty):not(.past):hover {
      border-color: var(--gold-dim);
      color: var(--text);
    }

    .cal-day.today {
      color: var(--gold);
      font-weight: 600;
    }

    .cal-day.selected {
      background: var(--gold);
      color: var(--bg);
      font-weight: 600;
      border-color: var(--gold);
    }

    .cal-day.past {
      opacity: 0.2;
      cursor: default;
    }

    .cal-day.empty {
      cursor: default;
    }

    .time-slots {
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 32px;
    }

    .time-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .time-slot {
      border: 1px solid var(--border);
      padding: 14px;
      text-align: center;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      cursor: pointer;
      transition: all 0.3s;
      color: var(--text-muted);
    }

    .time-slot:hover,
    .time-slot.selected {
      border-color: var(--gold);
      color: var(--gold);
      background: rgba(201, 168, 76, 0.05);
    }

    .time-slot.unavailable {
      opacity: 0.3;
      cursor: default;
      pointer-events: none;
    }

    /* FORMS */
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-bottom: 48px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .form-group.full {
      grid-column: 1 / -1;
    }

    .form-label {
      font-size: 0.6rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .form-input,
    .form-textarea {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 16px 20px;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      transition: border-color 0.3s;
      outline: none;
      width: 100%;
    }

    .form-input:focus,
    .form-textarea:focus {
      border-color: var(--gold-dim);
    }

    .form-textarea {
      resize: vertical;
      min-height: 120px;
    }

    /* STRIPE PAYMENT */
    .review-layout {
      display: grid;
      grid-template-columns: 1fr 400px;
      gap: 40px;
      margin-bottom: 48px;
    }

    .review-summary {
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 48px;
    }

    .review-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.8rem;
      margin-bottom: 40px;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--border);
    }

    .review-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 20px 0;
      border-bottom: 1px solid var(--border);
    }

    .review-row-label {
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 6px;
    }

    .review-row-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
    }

    .review-total {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 32px;
      margin-top: 16px;
    }

    .review-total-label {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .review-total-amount {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.5rem;
      color: var(--gold);
    }

    .payment-form {
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 40px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .payment-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      margin-bottom: 8px;
    }

    .payment-secure {
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .payment-secure::before {
      content: '🔒';
      font-size: 0.7rem;
    }

    #card-element {
      background: var(--surface3);
      border: 1px solid var(--border);
      padding: 16px 20px;
      transition: border-color 0.3s;
    }

    #card-element.focused {
      border-color: var(--gold-dim);
    }

    #card-errors {
      color: var(--error);
      font-size: 0.7rem;
      letter-spacing: 0.05em;
      min-height: 20px;
    }

    .pay-btn-wrap {
      position: relative;
    }

    .pay-spinner {
      display: none;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(8, 8, 8, 0.3);
      border-top-color: var(--bg);
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      position: absolute;
      right: 20px;
      top: 50%;
      transform: translateY(-50%);
    }

    @keyframes spin {
      to {
        transform: translateY(-50%) rotate(360deg);
      }
    }

    /* SUCCESS */
    #success-panel {
      display: none;
      text-align: center;
      padding: 80px 40px;
    }

    .success-icon {
      width: 80px;
      height: 80px;
      border: 1px solid var(--gold);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 40px;
      font-size: 2rem;
      animation: appear 0.6s ease;
    }

    @keyframes appear {
      from {
        transform: scale(0);
        opacity: 0
      }

      to {
        transform: scale(1);
        opacity: 1
      }
    }

    .success-title {
      font-family: 'Cormorant Garamond', serif;
