    }

    .toast {
      position: fixed;
      bottom: 32px;
      right: 32px;
      background: var(--surface2);
      border: 1px solid var(--border-gold);
      padding: 16px 24px;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      z-index: 9000;
      transform: translateY(100px);
      opacity: 0;
      transition: all 0.4s;
      max-width: 320px;
    }

    .toast.show {
      transform: translateY(0);
      opacity: 1;
    }

    .toast.error {
      border-color: var(--error);
      color: var(--error);
    }

    @media(max-width:900px) {
      nav {
        padding: 20px 24px;
      }

